# Read the uploaded file
CO2 <- read.csv("CPT_GR_data_format_CO2.csv", header = TRUE)

# Parse date column
CO2$date <- as.POSIXct(strptime(CO2$TIME, format = "%m/%d/%Y %H:%M", tz = "GMT"))

# Interpolate missing values in 'origdat'
CO2$origdat <- interp1(
  x = as.numeric(rownames(CO2[!is.na(CO2$origdat), ])),
  y = CO2$origdat[!is.na(CO2$origdat)],
  xi = as.numeric(rownames(CO2)),
  method = "spline"
)

# Mann-Kendall test results per year
MKmat <- matrix(ncol = 2, nrow = 0)
for (yr in 1994:2019) {
  Data <- selectByDate(CO2, year = yr)
  MK <- mk.test(Data$origdat)
  res <- round(MK$statistic, 2)
  MKmat <- rbind(MKmat, c(yr, res))
}
colnames(MKmat) <- c("Year", "Z_score")

# Prepare for plotting
zpos <- rep(1.96, nrow(MKmat))
zneg <- rep(-1.96, nrow(MKmat))
DataF <- data.frame(Year = MKmat[, 1], Z_score = MKmat[, 2], zpos, zneg)

# Plot with Plotly
plot_ly(DataF, x = ~Year, y = ~Z_score, type = 'bar', name = "MK Z-score") %>%
  add_trace(y = ~zpos, type = 'scatter', mode = 'lines', name = "+1.96",
            line = list(color = 'black', width = 2, dash = 'dot')) %>%
  add_trace(y = ~zneg, type = 'scatter', mode = 'lines', name = "-1.96",
            line = list(color = 'black', width = 2, dash = 'dot')) %>%
  layout(title = "Annual Mann-Kendall Trend: CO₂ (Cape Point)",
         xaxis = list(title = "Year"),
         yaxis = list(title = "Z-Score"))
