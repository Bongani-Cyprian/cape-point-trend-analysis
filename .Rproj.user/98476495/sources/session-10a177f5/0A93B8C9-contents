# Convert to time series object (daily data)
co2_ts <- ts(CO2$origdat, frequency = 365)  # Daily data with annual seasonality

# Seasonal-Trend Decomposition using LOESS (STL)
decomp <- stl(co2_ts, s.window = "periodic")

# Plot decomposition
autoplot(decomp) + 
  labs(title = "CO₂ Decomposition (Trend, Seasonality, Residuals)")

