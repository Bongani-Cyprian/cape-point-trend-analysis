  # --- Step 4: Seasonal Decomposition ---
  # Create a monthly time series
  start_year <- year(min(CO2$date))
  start_month <- month(min(CO2$date))
  CO2_ts <- ts(CO2$origdat, frequency = 12, start = c(start_year, start_month))
  
  # Decompose
  decomposed <- decompose(CO2_ts)
  autoplot(decomposed) + ggtitle("Seasonal Decomposition of CO2")
  
