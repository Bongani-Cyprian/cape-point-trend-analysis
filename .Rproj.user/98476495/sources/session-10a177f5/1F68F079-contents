  # Parse the date safely
  CO2$date <- as.POSIXct(CO2$TIME, format = "%m/%d/%Y %H:%M", tz = "GMT")
  
  # --- Step 2: Clean Missing Data ---
  # Remove rows where date or CO2 values are NA
  CO2 <- CO2[!is.na(CO2$date) & !is.na(CO2$origdat), ]
  
  # --- Step 3: Time Series Plot ---
  ggplot(CO2, aes(x = date, y = origdat)) +
