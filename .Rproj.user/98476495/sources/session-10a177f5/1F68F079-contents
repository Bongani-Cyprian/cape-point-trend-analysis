# Interpolate missing 'origdat' values
CO2$origdat <- interp1(
  x = as.numeric(rownames(CO2[!is.na(CO2$origdat), ]),
                 y = CO2$origdat[!is.na(CO2$origdat)],
                 xi = as.numeric(rownames(CO2)),
                 method = "spline"
  )
 
  MKmat <- matrix(ncol = 2, nrow = 0)
  for (yr in 1994:2019) {
    # Use 'date' column for filtering (required by selectByDate)
    Data <- selectByDate(CO2, year = yr)
    MK <- mk.test(Data$origdat)
    res <- round(MK$statistic, 2)
    MKmat <- rbind(MKmat, c(yr, res))
  }
  colnames(MKmat) <- c("Year", "Z_score")
  # Create numeric time variable from 'date'
  CO2$time_num <- as.numeric(CO2$date - min(CO2$date)) / 365.25
  
  # Fit linear model
  lm_fit <- lm(origdat ~ time_num, data = CO2)
  summary(lm_fit)
  
  # Plot diagnostics
  plot(lm_fit)  # Now works because 'lm_fit' exists 
